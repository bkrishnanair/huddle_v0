rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /events/{eventId}/gallery/{fileName} {
      // Allow any logged in user to read
      allow read: if request.auth != null;
      
      // Allow any logged in user to upload images < 5MB
      // Using 'allow write' to be more permissive during debugging
      allow write: if request.auth != null 
                   && request.resource.size < 5 * 1024 * 1024
                   && (request.resource == null || request.resource.contentType.matches('image/.*'));
    }
    
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
